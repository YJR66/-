<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VirtualCamera" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/anime_pink</item>
        <item name="colorPrimaryVariant">@color/anime_pink_dark</item>
        <item name="colorOnPrimary">@color/anime_text</item>
        <item name="colorSecondary">@color/anime_lavender</item>
        <item name="colorSecondaryVariant">@color/anime_lavender_dark</item>
        <item name="colorOnSecondary">@color/anime_text</item>
        <item name="android:windowBackground">@color/anime_bg</item>
        <item name="android:statusBarColor">@color/anime_bg</item>
        <item name="android:navigationBarColor">@color/anime_bg</item>
        <item name="materialButtonStyle">@style/AnimeButton</item>
    </style>

    <style name="AnimeButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">24dp</item>
        <item name="backgroundTint">@color/anime_pink</item>
        <item name="android:textColor">@color/anime_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="AnimeButton.Lavender">
        <item name="backgroundTint">@color/anime_lavender</item>
    </style>

    <style name="AnimeButton.Cancel">
        <item name="backgroundTint">@color/anime_cancel_bg</item>
        <item name="android:textColor">@color/anime_text_hint</item>
    </style>
</resources>
